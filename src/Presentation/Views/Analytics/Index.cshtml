@model AnalyticsViewModel
@{
    ViewData["Title"] = "Аналітика";
}

<h3 class="mb-4">Аналітика продажів</h3>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-bar-chart me-2 text-primary"></i>Продажі за категоріями
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Категорія</th>
                            <th class="text-end">Продано (шт.)</th>
                            <th class="text-end">Виручка</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.SalesByCategory)
                        {
                            <tr>
                                <td>@row.CategoryName</td>
                                <td class="text-end">@row.TotalQuantitySold</td>
                                <td class="text-end fw-semibold text-success">@row.TotalRevenue.ToString("N2") ₴</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-trophy me-2 text-warning"></i>Топ покупці (від 1000 ₴)
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Email</th>
                            <th class="text-end">Замовлень</th>
                            <th class="text-end">Витрачено</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (customer, i) in Model.TopCustomers.Select((c, i) => (c, i)))
                        {
                            <tr>
                                <td>
                                    @if (i == 0)
                                    {
                                        <i class="bi bi-trophy-fill text-warning me-1"></i>
                                    }
                                    @customer.Email
                                </td>
                                <td class="text-end">@customer.OrdersCount</td>
                                <td class="text-end fw-semibold text-success">@customer.TotalSpent.ToString("N2") ₴</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>