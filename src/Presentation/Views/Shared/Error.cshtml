@{
    Layout = "_Layout";
    ViewData["Title"] = "Помилка";
}

<div class="text-center py-5">
    <div class="display-1 text-danger mb-4">
        <i class="bi bi-exclamation-octagon"></i>
    </div>
    <h1 class="h2 mb-3">Ой! Щось пішло не так</h1>
    <p class="lead text-muted mb-4">@ViewData["ErrorMessage"]</p>

    <div class="d-flex justify-content-center gap-3">
        <button onclick="window.location.href=document.referrer;" class="btn btn-outline-dark px-4">
            <i class="bi bi-arrow-left"></i> Назад
        </button>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">
            На головну
        </a>
    </div>
</div>