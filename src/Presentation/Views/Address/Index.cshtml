@model Shop.Application.DTOs.CustomerAddressesResponseDto
@{
    ViewData["Title"] = "Мої адреси";
}

<h3 class="mb-4">Мої адреси</h3>

<div class="row g-4">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-white fw-semibold">Додати адресу</div>
            <div class="card-body p-4">
                <form asp-action="Add" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Країна</label>
                        <input name="Country" class="form-control" placeholder="Україна" maxlength="70" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Місто</label>
                        <input name="City" class="form-control" placeholder="Київ" maxlength="200" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Вулиця, будинок</label>
                        <input name="AddressLine" class="form-control" placeholder="вул. Хрещатик, 1" maxlength="400" required />
                    </div>
                    <div class="mb-3 form-check">
                        <input type="hidden" name="IsDefault" value="false" />
                        <input type="checkbox" name="IsDefault" value="true" class="form-check-input" id="isDefault" />
                        <label class="form-check-label" for="isDefault">Адреса за замовчуванням</label>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-plus-lg me-1"></i>Додати
                    </button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        @if (!Model.Addresses.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-geo-alt display-3 d-block mb-3"></i>
                Адреси не додані
            </div>
        }
        else
        {
            @foreach (var addr in Model.Addresses)
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-body d-flex justify-content-between align-items-start">
                        <div>
                            @if (addr.IsDefault)
                            {
                                <span class="badge bg-success mb-2">За замовчуванням</span>
                            }
                            <p class="mb-0 fw-semibold">@addr.Country, @addr.City</p>
                            <p class="text-muted mb-0 small">@addr.AddressLine</p>
                        </div>

                        @* Блок кнопок справа *@
                        <div class="d-flex align-items-center gap-2">
                            @if (addr.IsDefault)
                            {
                                <form asp-action="UnsetDefault" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@addr.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning" title="Прибрати за замовчуванням">
                                        <i class="bi bi-star-fill"></i> <span class="d-none d-md-inline">Прибрати</span>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="SetDefault" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@addr.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Зробити основною">
                                        <i class="bi bi-star"></i> <span class="d-none d-md-inline">За замовч.</span>
                                    </button>
                                </form>
                            }

                            @* Кнопка видалення (твоя іконка кошика) *@
                            <form asp-action="Delete" method="post" class="m-0" onsubmit="return confirm('Видалити цю адресу?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@addr.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>