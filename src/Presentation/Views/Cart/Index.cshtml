@model Shop.Application.DTOs.CartResponseDto
@{
    ViewData["Title"] = "Кошик";
}

<h3 class="mb-4">Кошик</h3>

@if (!Model.Items.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-cart-x display-3 d-block mb-3"></i>
        <p>Кошик порожній</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Перейти до товарів</a>
    </div>
}
else
{
    <div class="row align-items-start g-4">
        <div class="col-lg-8">
            @foreach (var item in Model.Items)
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3">
                            @if (item.Picture?.Length > 0)
                            {
                                <img src="data:image/jpeg;base64,@Convert.ToBase64String(item.Picture)"
                                     width="80" height="80" class="rounded object-fit-cover flex-shrink-0" />
                            }
                            <div class="flex-grow-1">
                                <h6 class="mb-1">@item.ProductName</h6>
                                <small class="text-muted">@item.Price.ToString("N2") ₴ / шт.</small>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <form asp-action="Decrease" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button type="submit" class="btn btn-outline-secondary btn-sm px-2">−</button>
                                </form>
                                <span class="fw-semibold" style="min-width:2rem;text-align:center">@item.Quantity</span>
                                <form asp-action="Increase" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button type="submit" class="btn btn-outline-secondary btn-sm px-2">+</button>
                                </form>
                            </div>
                            <div class="fw-bold text-success" style="min-width:5rem;text-align:right">
                                @item.TotalPrice.ToString("N2") ₴
                            </div>
                            <form asp-action="Remove" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" class="btn btn-link text-danger p-0">
                                    <i class="bi bi-trash fs-5"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h5 class="card-title">Підсумок</h5>
                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Разом:</span>
                        <span class="fs-4 fw-bold text-success">@Model.TotalPriceAmount.ToString("N2") ₴</span>
                    </div>
                    <a asp-controller="Order" asp-action="Create" class="btn btn-primary w-100 mt-3">
                        <i class="bi bi-bag-check me-1"></i>Оформити замовлення
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-link w-100 text-muted">
                        Продовжити покупки
                    </a>
                </div>
            </div>
        </div>
    </div>
}