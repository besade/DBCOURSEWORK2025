@model HomeViewModel
@{ ViewData["Title"] = "Товари"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Наші товари</h3>
</div>

<div class="mb-4 d-flex flex-wrap gap-2">
    <a asp-action="Index" asp-route-categoryId=""
       class="btn btn-sm @(Model.SelectedCategoryId == null ? "btn-dark" : "btn-outline-dark")">
        Усі категорії
    </a>
    @foreach (var cat in Model.Categories.Categories)
    {
        <a asp-action="Index" asp-route-categoryId="@cat.CategoryId"
           class="btn btn-sm @(Model.SelectedCategoryId == cat.CategoryId ? "btn-dark" : "btn-outline-dark")">
            @cat.CategoryName
        </a>
    }
</div>

@if (!Model.Products.Products.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-box-seam display-3 d-block mb-3"></i>
        Товарів не знайдено
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
        @foreach (var p in Model.Products.Products)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    @if (p.Picture?.Length > 0)
                    {
                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(p.Picture)"
                             class="card-img-top" style="height:200px;object-fit:cover;" alt="@p.Name" />
                    }
                    else
                    {
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center"
                             style="height:200px;">
                            <i class="bi bi-image text-muted fs-1"></i>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <h6 class="card-title flex-grow-1">@p.Name</h6>
                        <p class="fw-bold text-success fs-5 mb-3">@p.Price.ToString("N2") ₴</p>
                        <div class="d-flex gap-2">
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@p.Id"
                               class="btn btn-outline-primary btn-sm flex-grow-1">
                                <i class="bi bi-eye"></i> Детальніше
                            </a>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form asp-controller="Cart" asp-action="Add" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@p.Id" />
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <i class="bi bi-cart-plus"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    }

    @{
        var totalPages = (int)Math.Ceiling(Model.Products.TotalCount / 6.0);
        var cur = Model.Products.PageNumber;
    }

    @if (totalPages > 1)
    {
        <nav class="mt-4" aria-label="Пагінація">
            <ul class="pagination justify-content-center">
                <li class="page-item @(cur <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(cur - 1)" asp-route-categoryId="@Model.SelectedCategoryId">‹</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == cur ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@i" asp-route-categoryId="@Model.SelectedCategoryId">@i</a>
                    </li>
                }
                <li class="page-item @(cur >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(cur + 1)" asp-route-categoryId="@Model.SelectedCategoryId">›</a>
                </li>
            </ul>
        </nav>
    }