@model ProfileViewModel
@{
    ViewData["Title"] = "Мій профіль";
}

<div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow-sm text-center p-4">
            <i class="bi bi-person-circle text-muted" style="font-size:4rem;"></i>
            <h5 class="mt-3">@Model.Profile?.FullName</h5>
            <p class="text-muted mb-1"><i class="bi bi-envelope me-1"></i>@Model.Profile?.Email</p>
            <p class="text-muted mb-1"><i class="bi bi-telephone me-1"></i>@Model.Profile?.PhoneNumber</p>
            <p class="text-muted"><i class="bi bi-calendar me-1"></i>@Model.Profile?.DateOfBirth.ToString("dd.MM.yyyy")</p>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-white fw-semibold">Редагувати профіль</div>
            <div class="card-body p-4">
                <form asp-action="UpdateProfile" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label">Ім'я</label>
                            <input name="FirstName" class="form-control"
                                   value="@(Model.UpdateDto?.FirstName ?? Model.Profile?.FullName?.Split(' ').FirstOrDefault())" />
                            <span asp-validation-for="@Model.UpdateDto!.FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Прізвище</label>
                            <input name="LastName" class="form-control"
                                   value="@(Model.UpdateDto?.LastName ?? Model.Profile?.FullName?.Split(' ').LastOrDefault())" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Email</label>
                            <input name="Email" type="email" class="form-control"
                                   value="@(Model.UpdateDto?.Email ?? Model.Profile?.Email)" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Телефон</label>
                            <input name="PhoneNumber" class="form-control" placeholder="+380XXXXXXXXX"
                                   value="@(Model.UpdateDto?.PhoneNumber ?? Model.Profile?.PhoneNumber)" />
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-floppy me-1"></i>Зберегти зміни
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>